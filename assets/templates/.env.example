# Telegram bot credentials
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=-1001234567890
ALLOWED_USER_IDS=123456789,987654321

# Goose agent — Claude Code subscription (ACP, no API key needed)
GOOSE_PROVIDER=claude-acp
GOOSE_MODEL=default   # default=opus, sonnet, haiku

# Alternative: direct Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...
# GOOSE_PROVIDER=anthropic
# GOOSE_MODEL=claude-opus-4-6

# Alternative: Z.AI (GLM) — includes web search MCP
# GOOSE_PROVIDER=z-ai
# GOOSE_MODEL=default
# ZAI_API_KEY=your_zai_api_key_here  # Get from https://z.ai/manage-apikey/apikey-list

# GitHub (for repo cloning and MCP)
GITHUB_TOKEN=ghp_...

# Session settings
WORKSPACE_ROOT=/tmp/minions-workspace
MAX_CONCURRENT_SESSIONS=5
SESSION_TIMEOUT_MS=3600000
ACTIVITY_THROTTLE_MS=3000
MIN_SEND_INTERVAL_MS=3500
TEXT_FLUSH_DEBOUNCE_MS=5000
ACTIVITY_EDIT_DEBOUNCE_MS=5000

# Browser MCP (Playwright) — gives minions eyes via headless Chromium
ENABLE_BROWSER_MCP=true

# Z.AI Web Search MCP — only enabled when GOOSE_PROVIDER=z-ai (uses ZAI_API_KEY from above)
ENABLE_ZAI_MCP=true
