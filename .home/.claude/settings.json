{
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "DISABLE_COST_WARNINGS": "1",
    "MAX_MCP_OUTPUT_TOKENS": "32000"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(explorer)",
      "Agent(planner)",
      "Agent(technical-architect)",
      "Agent(git-commit-specialist)",
      "mcp__playwright__*"
    ]
  },
  "sandbox": {
    "enabled": false
  }
}
