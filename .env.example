# ───────────────────────────────────────────────────────────────────────────
# Minimum to boot locally
# ───────────────────────────────────────────────────────────────────────────
#
# Leave everything in this file blank and run `npm run dev:full` — local mode
# fills in sensible defaults automatically:
#
#   WORKSPACE_ROOT        → ./.minion-data
#   MINION_API_TOKEN      → auto-generated and saved to WORKSPACE_ROOT/.api-token
#   API_PORT              → 8080
#   GITHUB_TOKEN          → `gh auth token` if the gh CLI is authenticated
#   CORS_ALLOWED_ORIGINS  → localhost:5173, localhost:3000, localhost:$API_PORT
#
# Run `npm run doctor` to see what's missing and how to fix each item.

# Only strictly required if `gh auth login` hasn't run on the host.
# GITHUB_TOKEN=ghp_...

# ───────────────────────────────────────────────────────────────────────────
# Telegram (optional)
# ───────────────────────────────────────────────────────────────────────────
# Skip these entirely to run PWA-only. Set all three to enable the bot.

# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=-1001234567890
# ALLOWED_USER_IDS=123456789,987654321

# ───────────────────────────────────────────────────────────────────────────
# Everything below is optional — override defaults only when you need to.
# ───────────────────────────────────────────────────────────────────────────

# ── Claude / Goose provider ───────────────────────────────────────────────
# Default = claude-acp (uses your Claude Code subscription — no API key).
# Requires: npm install -g @anthropic-ai/claude-code @zed-industries/claude-agent-acp
# Then one-time: claude auth login

# GOOSE_PROVIDER=claude-acp
# GOOSE_MODEL=default             # default=opus | sonnet | haiku

# Alternative: direct Anthropic API key
# GOOSE_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# GOOSE_MODEL=claude-opus-4-6

# Alternative: Z.AI (GLM) — enables the z-ai web search MCP
# GOOSE_PROVIDER=z-ai
# GOOSE_MODEL=default
# ZAI_API_KEY=your_zai_api_key_here     # https://z.ai/manage-apikey/apikey-list

# ── GitHub App (optional, replaces PAT with installation tokens) ─────────
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_INSTALLATION_ID=12345678

# ── HTTP API + PWA ───────────────────────────────────────────────────────
# API_PORT=8080
# MINION_API_TOKEN=                     # 32+ hex chars, `openssl rand -hex 32`
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Session & workspace tuning ───────────────────────────────────────────
# WORKSPACE_ROOT=./.minion-data
# MAX_CONCURRENT_SESSIONS=5
# SESSION_TIMEOUT_MS=3600000
# ACTIVITY_THROTTLE_MS=3000
# TEXT_FLUSH_DEBOUNCE_MS=5000
# ACTIVITY_EDIT_DEBOUNCE_MS=5000
# MIN_SEND_INTERVAL_MS=3500             # Telegram API rate limit guard

# ── MCP servers (all default: true) ──────────────────────────────────────
# ENABLE_BROWSER_MCP=true               # Playwright — needs the browser binary at PLAYWRIGHT_BROWSERS_PATH
# ENABLE_GITHUB_MCP=true                # GitHub — needs GITHUB_TOKEN
# ENABLE_CONTEXT7_MCP=true              # Context7 — public docs, no auth
# ENABLE_SENTRY_MCP=true                # Sentry — needs SENTRY_ACCESS_TOKEN
# ENABLE_SUPABASE_MCP=true              # Supabase — needs SUPABASE_ACCESS_TOKEN
# ENABLE_ZAI_MCP=true                   # Z.AI web search — only with GOOSE_PROVIDER=z-ai

# SENTRY_ACCESS_TOKEN=sntrys_...
# SENTRY_ORG_SLUG=
# SENTRY_PROJECT_SLUG=
# SUPABASE_ACCESS_TOKEN=sbt_...
# SUPABASE_PROJECT_REF=

# ── Sentry error reporting (for the engine itself — optional) ────────────
# SENTRY_DSN=https://your-key@o123.ingest.us.sentry.io/456

# ── Local-mode override ──────────────────────────────────────────────────
# Force-disable local mode smart defaults (e.g. running locally against a
# production-like setup):
# MINION_LOCAL_MODE=false
