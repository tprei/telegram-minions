# =============================================================================
# Telegram bot credentials (required)
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=-1001234567890
ALLOWED_USER_IDS=123456789,987654321

# =============================================================================
# Agent provider configuration
# =============================================================================

# Goose agent — Claude Code subscription (ACP, no API key needed)
# Requires: npm install -g @zed-industries/claude-agent-acp
# Then: claude auth login
GOOSE_PROVIDER=claude-acp
GOOSE_MODEL=sonnet   # sonnet (default), opus, haiku

# Alternative: direct Anthropic API key (set GOOSE_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# GOOSE_PROVIDER=anthropic
# GOOSE_MODEL=claude-opus-4-6

# Alternative: Z.AI (GLM) — includes web search MCP
# GOOSE_PROVIDER=z-ai
# GOOSE_MODEL=default
# ZAI_API_KEY=your_zai_api_key_here  # Get from https://z.ai/manage-apikey/apikey-list

# Claude model overrides for planning/thinking/review modes (default: opus)
# PLAN_MODEL=opus
# THINK_MODEL=opus
# REVIEW_MODEL=opus

# =============================================================================
# GitHub (required for repo cloning and MCP)
# =============================================================================
GITHUB_TOKEN=ghp_...

# =============================================================================
# Workspace and session settings
# =============================================================================
WORKSPACE_ROOT=/tmp/minions-workspace
MAX_CONCURRENT_SESSIONS=5          # max parallel agent sessions (default: 5)
MAX_DAG_CONCURRENCY=4              # max parallel tasks within a DAG (default: 4)
MAX_SPLIT_ITEMS=5                  # max sub-tasks from /split (default: 5)
SESSION_TIMEOUT_MS=3600000         # hard session timeout in ms (default: 1h)
SESSION_INACTIVITY_TIMEOUT_MS=900000  # kill session after inactivity (default: 15min)
SESSION_TOKEN_BUDGET=200000        # max tokens per session (default: 200000)
SESSION_BUDGET_USD=10              # max spend per session in USD (default: 10)
MAX_CONVERSATION_LENGTH=100        # max messages in a conversation (default: 100)
SESSION_STALE_TTL_MS=172800000     # time before stale sessions are cleaned up (default: 2 days)
CLEANUP_INTERVAL_MS=3600000        # how often to run cleanup (default: 1h)

# =============================================================================
# Observer — Telegram message timing
# =============================================================================
ACTIVITY_THROTTLE_MS=3000          # min interval between activity updates (default: 3s)
MIN_SEND_INTERVAL_MS=3500          # min interval between Telegram sends (default: 3.5s)
TEXT_FLUSH_DEBOUNCE_MS=5000        # debounce before flushing text buffer (default: 5s)
ACTIVITY_EDIT_DEBOUNCE_MS=5000     # debounce before editing activity msg (default: 5s)

# =============================================================================
# CI babysitting — auto-fix CI failures after PR creation
# =============================================================================
CI_BABYSIT_ENABLED=true            # enable CI failure auto-fix (default: true)
CI_BABYSIT_MAX_RETRIES=2           # max fix attempts per PR (default: 2)
CI_POLL_INTERVAL_MS=30000          # how often to poll CI status (default: 30s)
CI_POLL_TIMEOUT_MS=600000          # give up waiting for CI after (default: 10min)
DAG_CI_POLICY=warn                 # CI failure policy for DAGs: block, warn, skip (default: warn)

# =============================================================================
# MCP servers — each can be toggled independently
# =============================================================================
ENABLE_BROWSER_MCP=true            # Playwright: headless Chromium for web browsing
ENABLE_GITHUB_MCP=true             # GitHub: PRs, issues, reviews, search (needs GITHUB_TOKEN)
ENABLE_CONTEXT7_MCP=true           # Context7: up-to-date library docs for any dependency
ENABLE_SENTRY_MCP=true             # Sentry: error tracking, issue search, stack traces
ENABLE_SUPABASE_MCP=true           # Supabase: database queries, migrations, logs
ENABLE_ZAI_MCP=true                # Z.AI: web search (only when GOOSE_PROVIDER=z-ai)

SENTRY_ACCESS_TOKEN=sntrys_...
SENTRY_ORG_SLUG=your-org           # optional: scope Sentry MCP to a specific organization
SENTRY_PROJECT_SLUG=your-project   # optional: scope Sentry MCP to a specific project

SUPABASE_ACCESS_TOKEN=sbt_...      # required for Supabase MCP
SUPABASE_PROJECT_REF=your-project-ref  # optional: scope to a specific project

# =============================================================================
# Session environment passthrough
# =============================================================================
# Comma-separated list of extra env var names to forward into agent sessions.
# Only vars that exist in the parent process are passed; missing vars are skipped.
# SESSION_ENV_PASSTHROUGH=MY_API_KEY,DATABASE_URL,CUSTOM_SECRET_TOKEN

# =============================================================================
# API server (optional — for web dashboard)
# =============================================================================
# API_PORT=3000                    # HTTP port for the dashboard API

# =============================================================================
# Sentry error reporting (optional — omit to disable)
# =============================================================================
# SENTRY_DSN=https://your-key@o123.ingest.us.sentry.io/456
