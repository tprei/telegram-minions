{
  "name": "@tprei/telegram-minions",
  "version": "1.2.6",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "telegram-minion": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "assets/"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "start": "node dist/cli.js",
    "dev": "npx tsx src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sentry/node": "^9.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "dotenv": "^16.0.0"
  },
  "peerDependenciesMeta": {
    "dotenv": {
      "optional": true
    }
  }
}
